  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@logtape/logtape": "^2.1.5",
    "@logtape/pretty": "^2.1.5",
    "@opentui/core": "^0.4.0",
    "@opentui/core-win32-x64": "0.4.0",
    "ssh2-no-cpu-features": "^2.0.0",
    "vterm.js": "^0.5.0"
  }
}
